# Copy to .env and fill in your project's values.
# These are read by Vite at build time and inlined into the client bundle via
# `$env/static/public`. ONLY the PUBLIC_ prefix is exposed to client code.
#
# This is a static-SPA (no server), so only PUBLIC_ vars work, and that's fine:
# the publishable/anon key is meant to be public — RLS protects your data.
# NEVER put the sb_secret_… / service_role key here (no server to hide it).

PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"

# Prefer the new publishable key (sb_publishable_…) over the legacy anon key.
PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxx"
